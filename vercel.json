{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/n8n/(.*)", "destination": "https://invoice-infant-thunder-filed.trycloudflare.com/$1" },
    { "source": "/((?!assets/).*)", "destination": "/index.html" }
  ]
}
