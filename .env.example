# Supabase Configuration
# Get these from: https://supabase.com/dashboard → Project Settings → API

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# n8n Automation
# Webhook URL from n8n (e.g., http://localhost:5678/webhook/leadboost)
VITE_N8N_WEBHOOK_URL=
# n8n REST API base URL (for workflow triggers)
VITE_N8N_API_URL=http://localhost:5678/api/v1
# n8n API key (create in n8n Settings → API)
VITE_N8N_API_KEY=

# Mailpit (local email testing)
MAIL_FROM=noreply@leadboost.local

# App
APP_URL=http://localhost:5173
